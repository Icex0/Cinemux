# Copy this file to `.env` (for Docker Compose) or `.env.local` (for `npm run dev`).

# ── Required ─────────────────────────────────────────────────────────
# Free TMDB v3 API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Embed providers ──────────────────────────────────────────────────
# Cinemux is a metadata + iframe-player frontend and ships with no embed
# sources configured. A community-maintained set is available at:
#
# >> https://pastebin.com/pP95C0cA
#
# Use at least the alpha provider.
#
# Each provider has 4 vars: NAME (display label in the UI), ORIGIN (the
# iframe's origin, used for postMessage filtering), MOVIE template, TV
# template. A provider is hidden from the source switcher unless both the
# MOVIE and TV templates are set.
#
# URL templates support these placeholders, substituted at runtime:
#   {id} {season} {episode} {startAt} {sub}
#
# The Alpha slot is treated as the canonical provider — it must use an
# embed that emits MEDIA_DATA / playerstatus events for the watch-party
# sync and "Continue Watching" features to work.

NEXT_PUBLIC_PROVIDER_ALPHA_NAME=Alpha
NEXT_PUBLIC_PROVIDER_ALPHA_ORIGIN=
NEXT_PUBLIC_PROVIDER_ALPHA_MOVIE=
NEXT_PUBLIC_PROVIDER_ALPHA_TV=

NEXT_PUBLIC_PROVIDER_BETA_NAME=Beta
NEXT_PUBLIC_PROVIDER_BETA_ORIGIN=
NEXT_PUBLIC_PROVIDER_BETA_MOVIE=
NEXT_PUBLIC_PROVIDER_BETA_TV=

NEXT_PUBLIC_PROVIDER_GAMMA_NAME=Gamma
NEXT_PUBLIC_PROVIDER_GAMMA_ORIGIN=
NEXT_PUBLIC_PROVIDER_GAMMA_MOVIE=
NEXT_PUBLIC_PROVIDER_GAMMA_TV=

NEXT_PUBLIC_PROVIDER_DELTA_NAME=Delta
NEXT_PUBLIC_PROVIDER_DELTA_ORIGIN=
NEXT_PUBLIC_PROVIDER_DELTA_MOVIE=
NEXT_PUBLIC_PROVIDER_DELTA_TV=

# ── Watch-party (optional) ───────────────────────────────────────────
# WebSocket URL the client connects to. Baked into the client bundle at
# build time. Default works for local dev.
# Examples:
#   ws://localhost:3001                       (npm run dev)
#   wss://room.example.com                    (production behind TLS)
#   wss://abcd-1234.ngrok-free.app            (ngrok tunnel)
NEXT_PUBLIC_ROOM_WS_URL=ws://localhost:3001

# Comma-separated allowlist for the room server's Origin check.
# Use "*" to allow any origin (dev/ngrok). For prod, set explicit domains.
# Example: https://cinemux.example.com,https://staging.example.com
ROOM_ALLOWED_ORIGINS=*

# Room server port inside the container. Compose maps this to the host;
# usually no need to change.
ROOM_PORT=3001

# ── Docker host ports (optional) ─────────────────────────────────────
# Override only if 3000/3001 are taken on your machine.
WEB_PORT=3000

# ── Caddy reverse proxy (optional, --profile proxy) ──────────────────
# Default is HTTP-only on :80 (good for localhost / ngrok). Set to a real
# domain to have Caddy auto-issue a Let's Encrypt cert and serve HTTPS.
#
# SITE_ADDRESS=cinemux.example.com
#
# When Caddy is in front of a real domain, expose web/room only on localhost
# so external traffic must go through Caddy. Compose's port mapping accepts
# IP:PORT — uncomment these to bind only to the loopback interface:
#
# WEB_PORT=127.0.0.1:3000
# ROOM_PORT=127.0.0.1:3001

# ── GIPHY API key (optional) ──────────────────────────────────────────
# Used for the "Gif" button in the chatroom. Limited to 100 requests per day according to the docs.
GIPHY_API_KEY=